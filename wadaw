radarDots={}
local function updateRadar()
    radarOuter.Visible=Cfg.Radar; if not Cfg.Radar then return end
    local localChar=LocalPlayer.Character; local localRoot=localChar and localChar:FindFirstChild("HumanoidRootPart"); if not localRoot then return end
    local half=(RS/2)-8
    for k,dot in pairs(radarDots) do if not Players:FindFirstChild(k) then dot:Destroy(); radarDots[k]=nil end end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local char=p.Character; local root=char and char:FindFirstChild("HumanoidRootPart")
            if root then
                if not radarDots[p.Name] then local dot=Instance.new("Frame"); dot.BorderSizePixel=0; dot.ZIndex=4; dot.Parent=radarMask; Instance.new("UICorner",dot).CornerRadius=UDim.new(0.5,0); radarDots[p.Name]=dot end
                local dot=radarDots[p.Name]; dot.BackgroundColor3=getColor(p); local ds=Cfg.RadarDotSize; dot.Size=UDim2.new(0,ds,0,ds)
                local relPos=root.Position-localRoot.Position; local angle=0
                if Cfg.RadarRotate then angle=-math.atan2(Camera.CFrame.LookVector.Z,Camera.CFrame.LookVector.X)+math.pi/2 end
                local rotX=-(relPos.X*math.cos(angle)-relPos.Z*math.sin(angle)); local rotZ=relPos.X*math.sin(angle)+relPos.Z*math.cos(angle)
                local rawX=rotX*(half/Cfg.RadarRange); local rawZ=rotZ*(half/Cfg.RadarRange); local dist2=math.sqrt(rawX*rawX+rawZ*rawZ)
                local cx2=dist2>half and rawX/dist2*half or rawX; local cz2=dist2>half and rawZ/dist2*half or rawZ
                dot.Position=UDim2.new(0.5,cx2-ds/2,0.5,-cz2-ds/2); dot.Visible=true
            else if radarDots[p.Name] then radarDots[p.Name].Visible=false end end
        end
    end
end

