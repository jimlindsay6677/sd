local function updateTargetHUD(isAimbotHeld,aimTgt,aimPart)
    local targetHUD=targetHudRefs.frame
    local targetHUDStroke=targetHudRefs.stroke
    local targetThumb=targetHudRefs.thumb
    local targetThumbStroke=targetHudRefs.thumbStroke
    local targetName=targetHudRefs.name
    local targetInfo=targetHudRefs.info
    local targetHPFill=targetHudRefs.hpFill
    local targetMeta=targetHudRefs.meta
    local targetMore=targetHudRefs.more
    if not (Cfg.ShowHUD and isAimbotHeld and aimTgt and aimPart) then
        targetHUD.Visible=false
        return
    end
    local targetChar=nil
    local targetHum=nil
    local targetNameText=""
    local targetWeaponText=""
    local targetKD="K/D  --"
    local targetType="NPC"
    if aimTgt.type=="player" and aimTgt.obj then
        local playerObj=aimTgt.obj
        targetChar=playerObj.Character
        targetHum=targetChar and targetChar:FindFirstChildOfClass("Humanoid")
        targetNameText=getShownPlayerName(playerObj)
        targetWeaponText=getWeaponName(targetChar) or "None"
        targetKD=getPlayerKDText(playerObj)
        targetType="Player"
        targetThumb.Image="rbxthumb://type=AvatarHeadShot&id="..playerObj.UserId.."&w=100&h=100"
    else
        targetChar=aimPart:FindFirstAncestorOfClass("Model")
        targetHum=targetChar and targetChar:FindFirstChildOfClass("Humanoid")
        targetNameText=(targetChar and targetChar.Name) or "Unknown NPC"
        targetWeaponText=getWeaponName(targetChar) or "None"
        targetThumb.Image=""
    end
    local hpNow=targetHum and targetHum.Health or 0
    local hpMax=targetHum and math.max(targetHum.MaxHealth,1) or 100
    local hpPctTarget=math.clamp(hpNow/hpMax,0,1)
    local targetDistance=(aimPart.Position-Camera.CFrame.Position).Magnitude
    local visibleNow=select(1,isTargetVisible(aimTgt,aimPart))
    targetHUD.Visible=true
    targetName.Text=targetNameText
    targetInfo.Text=string.format("%s  |  %s",targetWeaponText,targetType)
    targetHPFill.Size=UDim2.new(hpPctTarget,0,1,0)
    targetHPFill.BackgroundColor3=Color3.fromRGB(math.floor(255*(1-hpPctTarget)),math.floor(255*hpPctTarget),50)
    targetMeta.Text=string.format("%dst  |  HP %.0f/%.0f  |  %s",math.floor(targetDistance+0.5),hpNow,hpMax,targetKD)
    targetMore.Text=visibleNow and "Status  Visible / Locked" or "Status  Blocked / Locked"
    targetMore.TextColor3=visibleNow and Color3.fromRGB(130,230,160) or Color3.fromRGB(255,150,120)
    targetHUDStroke.Color=visibleNow and Color3.fromRGB(110,255,140) or Color3.fromRGB(255,110,110)
    targetThumbStroke.Color=targetHUDStroke.Color
end

