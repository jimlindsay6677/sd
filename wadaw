            return true
        end
        if (obj:IsA("ValueBase") or obj:IsA("ObjectValue")) and objectHasLookupAttribute(obj,normalizedMatch) then
            return true
        end
        local commonChildren={"Item","item","ItemName","itemname","Name","name","DisplayName","displayname"}
        for _,childName in ipairs(commonChildren) do
            local child=obj:FindFirstChild(childName)
            if child and (tokenMatchesTrackedName(child.Name,normalizedMatch,matchLower) or tokenMatchesTrackedName(getLookupMatchValue(child),normalizedMatch,matchLower) or objectHasLookupAttribute(child,normalizedMatch)) then
                return true
            end
        end
        for _,child in ipairs(obj:GetChildren()) do
            if child:IsA("ValueBase") or child:IsA("ObjectValue") then
                if tokenMatchesTrackedName(child.Name,normalizedMatch,matchLower) or tokenMatchesTrackedName(getLookupMatchValue(child),normalizedMatch,matchLower) or objectHasLookupAttribute(child,normalizedMatch) then
