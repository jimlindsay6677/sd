local function syncNPCModel(model)
    if not model then
        npcState.cacheDirty=true
        return
    end
    if not model:IsA("Model") or Players:GetPlayerFromCharacter(model) then
        npcState.registry[model]=nil
        npcState.cacheDirty=true
        return
    end
    local hum=model:FindFirstChildOfClass("Humanoid")
    local root=getModelRoot(model)
    if root and model:IsDescendantOf(workspace) and ((hum and hum.MaxHealth>0) or isAIZoneModel(model)) then
        npcState.registry[model]={humanoid=hum,model=model,root=root}
    else
        npcState.registry[model]=nil
    end
    npcState.cacheDirty=true
end
local function rebuildNPCCache()
    table.clear(npcState.cache)
    for model,entry in pairs(npcState.registry) do
        local hum=entry.humanoid
        local root=entry.root
        if model and model.Parent and root and root.Parent and ((hum and hum.Parent and hum.MaxHealth>0) or isAIZoneModel(model)) then
            npcState.cache[#npcState.cache+1]={humanoid=hum,model=model,root=root}
        else
            npcState.registry[model]=nil
        end
    end
    npcState.cacheDirty=false
end
local function refreshNPCCache(forceFull)
    if forceFull then
        table.clear(npcState.registry)
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") then
                syncNPCModel(obj)
            end
        end
    end
    if npcState.cacheDirty or forceFull then
        rebuildNPCCache()
    end
end

