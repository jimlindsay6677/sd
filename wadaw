function hudState.invViewerBuildItemMap(force)
    local state=hudState.invViewer
    if state.itemMap and not force then return state.itemMap end
    state.itemMap={}
    for _,obj in ipairs(ReplicatedStorage:GetDescendants()) do
        local props=obj:FindFirstChild("ItemProperties")
        local icon=props and props:FindFirstChild("ItemIcon")
        if props and icon and icon:IsA("ImageLabel") then
            state.itemMap[obj.Name]=obj
        end
    end
    return state.itemMap
end

function hudState.invViewerGetIcon(itemName)
    local entry=hudState.invViewerBuildItemMap()[tostring(itemName or "")]
    local props=entry and entry:FindFirstChild("ItemProperties")
    local icon=props and props:FindFirstChild("ItemIcon")
    return (icon and icon.Image) or "rbxassetid://12459616555"
end

function hudState.invViewerResolveInventory(target)
    if not target then return nil end
    if target:IsA("Player") then
        local repPlayers=ReplicatedStorage:FindFirstChild("Players")
        local repEntry=repPlayers and repPlayers:FindFirstChild(target.Name)
        return repEntry and repEntry:FindFirstChild("Inventory")
    end
    return target:FindFirstChild("Inventory")
end

function hudState.invViewerGetTarget(now)
    local tgt=getCachedTarget(now)
