function hudState.updateInventoryViewer(now)
    local state=hudState.invViewer
    if not state.frame then return end
    if not Cfg.InventoryViewerEnabled or not (Cfg.InventoryViewerMode=="Always" or state.held) then
        state.frame.Visible=false; return
    end
    local target=hudState.invViewerGetTarget(now)
    local inventory=hudState.invViewerResolveInventory(target)
    state.frame.Visible=true
    if target then state.target.Text=Cfg.InvCheckTarget and ("Target  "..target.Name) or "Target locked"
    else state.target.Text="No player target" end
    if not inventory then
        state.status.Text="Inventory unavailable"; state.status.TextColor3=Color3.fromRGB(255,90,90); hudState.invViewerClear(); return
    end
    state.status.TextColor3=Color3.fromRGB(150,200,150)
