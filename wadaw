        return original.CustomBeam.Beam
    end
    local a0=Instance.new("Attachment")
    local a1=Instance.new("Attachment")
    a0.Name="XFentTracerBeamA0"
    a1.Name="XFentTracerBeamA1"
    a0.Position=Vector3.new(0,0,instRoot.Size.Z*0.5)
    a1.Position=Vector3.new(0,0,-instRoot.Size.Z*0.5)
    a0.Parent=instRoot
    a1.Parent=instRoot
    local beam=Instance.new("Beam")
    beam.Name="XFentTracerBeam"
