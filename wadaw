function itemLookup.markDirty(forceRefresh)
    local now=tick()
    if not forceRefresh and now-itemLookup.lastDirtyMark<itemLookup.dirtyCooldown then
        return
    end
    itemLookup.lastDirtyMark=now
    itemLookup.dirty=true
    -- Only reset the timer for explicit/forced refreshes. Passive dirty marks
    -- should wait for the normal scan interval instead of rescanning instantly.
    if forceRefresh then
        itemLookup.lastScan=0
    end
    if forceRefresh then
        itemLookup.refresh(true)
    else
        itemLookup.status=#itemLookup.selected>0 and ("Tracking "..#itemLookup.selected.." item(s)") or "Pick an item from the list"
            refreshLookupStatus()
            if itemLookup.refreshUI then itemLookup.refreshUI() end
        end
    end
    function itemLookup.isRelevantDescendant(obj)
        if not obj then return false end
        local current=obj
        while current and current~=workspace and current~=game:GetService("ReplicatedStorage") do
            local key=normalizeLookupName(current.Name)
            if key=="containers" or key=="droppeditems" then
                return true
            end
            -- IsDescendantOf is the correct API here; FindFirstAncestor expects
            -- a string name and was causing the item lookup error spam.
            if key=="inventory" and current:IsDescendantOf(game:GetService("ReplicatedStorage")) then
                return true
            end
            current=current.Parent
        end
        return false
    end
    function itemLookup.render()
        for _,entry in ipairs(itemLookup.labels) do
            if entry.gui then
                entry.gui.Enabled=false
            end
        end
        if not Cfg.ItemLookup then return end
        local char=LocalPlayer.Character
        local lr=char and char:FindFirstChild("HumanoidRootPart")
        if not lr then return end
        local now=tick()
    local lookupDue=now-itemLookup.lastScan>=getLookupScanInterval()
    if lookupDue and (itemLookup.dirty or itemLookup.lastScan==0) then
        itemLookup.dirty=false
        itemLookup.refresh(itemLookup.lastScan==0)
        itemLookup.lastVisibleUpdate=now
    elseif now-itemLookup.lastVisibleUpdate>=itemLookup.visibleUpdateInterval then
            itemLookup.lastVisibleUpdate=now
            rebuildVisibleLookupTargets()
        end
        local idx=0
        local staleCount=0
        for _,target in ipairs(itemLookup.visibleTargets) do
            local pos=(target.obj and getWorldPos(target.obj)) or target.pos
            target.pos=pos
            if pos then
                idx=idx+1
                ensureLookupLabel(idx)
                itemLookup.labels[idx].obj=target.obj
                local dist=math.floor((pos-lr.Position).Magnitude+0.5)
                local lookupText=string.format("%s\nStuds %d",target.name,dist)
                -- Keep lookup labels clearly above the tracked target so they read
                -- like the older build instead of sitting inside the object.
                local drawPos=pos+Vector3.new(0,target.kind=="player" and 7.8 or 4.6,0)
                placeLookupLabel(itemLookup.labels[idx],drawPos,lookupText)
            else
                staleCount=staleCount+1
            end
        end
        if staleCount>0 then
            itemLookup.markDirty(false)
        end
    end
    function itemLookup.cleanup()
        for _,entry in ipairs(itemLookup.labels) do
            pcall(function() if entry.gui then entry.gui:Destroy() end end)
        end
    end
    itemLookup.refreshStatus=refreshLookupStatus
end

