    else state.status.Text=(Cfg.InventoryViewerMode=="Always" and "Always on" or Cfg.InventoryViewerMode=="Toggle" and "Toggle mode" or "Hold mode") end
    hudState.invViewerPopulate(inventory)
    for i,slot in ipairs(state.stashSlots or {}) do
        local visible=Cfg.FullInventoryChecker and slot.Visible; slot.Visible=visible
        if state.stashQty and state.stashQty[i] then state.stashQty[i].Visible=visible and state.stashQty[i].Text~="" end
    end
