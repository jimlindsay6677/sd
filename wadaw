    beam.Attachment1=a1
    beam.FaceCamera=true
    beam.LightEmission=1
    beam.LightInfluence=0
    beam.Parent=instRoot
    original.CustomBeam={A0=a0,A1=a1,Beam=beam}
    return beam
end

