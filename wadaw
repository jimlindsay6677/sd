        if not ok or type(attrs)~="table" then return false end
        for key,val in pairs(attrs) do
            if tokenMatchesTrackedName(key,normalizedMatch,normalizedMatch) then
                return true
            end
            if type(val)=="string" and tokenMatchesTrackedName(val,normalizedMatch,normalizedMatch) then
                return true
