local function loadConfig()
    if not (readfile and isfile) then
        return false,"readfile unavailable"
    end
    if not isfile("XFent_config.json") then
        return false,"missing file"
    end
    local ok,text=pcall(function()
        return readfile("XFent_config.json")
    end)
    if not ok then
        return false,"read failed"
    end
    local parsedOk,data=pcall(function()
        return game:GetService("HttpService"):JSONDecode(text)
    end)
    if not parsedOk or type(data)~="table" then
        return false,"decode failed"
    end
    mergeConfig(Cfg,data)
    if applyColor then
        pcall(applyColor,Cfg.ThemeColor or THEME.RED)
    else
        local c=Cfg.ThemeColor or THEME.RED
        THEME.RED=c
        THEME.DARKRED=Color3.fromRGB(math.max(0,math.floor(c.R*255*0.43)),math.max(0,math.floor(c.G*255*0.04)),math.max(0,math.floor(c.B*255*0.04)))
        Cfg.BoxColor=c
        for _,t in ipairs(colorTargets) do pcall(function() t.obj[t.prop]=c end) end
    end
    refreshConfigUI()
    if applySavedUIPositions then
        pcall(applySavedUIPositions)
        task.defer(function()
            pcall(applySavedUIPositions)
            pcall(refreshConfigUI)
        end)
    end
    return true
end

