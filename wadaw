function bulletTracerState.applyStyle(instRoot, trail, beam, original)
    local tracerColor=bulletTracerState.getColor()
    local style=bulletTracerState.getStyleConfig()
    local visibleNow=not original or tick()>=(original.ShowAt or 0)
    if instRoot and instRoot:IsA("BasePart") then
        instRoot.Material=Enum.Material.Neon
        instRoot.Color=tracerColor
        instRoot.Transparency=visibleNow and (style.PartTransparency or 0) or 1
        if original and original.Size then
            local s=original.Size
            local mul=style.PartScale or Vector3.new(1,1,1)
            instRoot.Size=Vector3.new(
                math.max(0.03,s.X*mul.X),
                math.max(0.03,s.Y*mul.Y),
                math.max(0.03,s.Z*mul.Z)
            )
        end
    end
    if trail then
        trail.Color=ColorSequence.new(tracerColor)
        trail.Lifetime=math.max(trail.Lifetime or 0, Cfg.BulletTracerLifetime)
        trail.Enabled=visibleNow and style.UseTrail~=false
        trail.FaceCamera=true
        trail.Transparency=style.TrailTransparency or NumberSequence.new({
            NumberSequenceKeypoint.new(0,0),
            NumberSequenceKeypoint.new(1,1),
        })
        trail.WidthScale=style.WidthScale or NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.26),
            NumberSequenceKeypoint.new(1,0),
        })
    end
    if style.UseBeam and not beam then
        beam=bulletTracerState.ensureBeam(instRoot, original)
    end
    if beam then
        beam.Color=ColorSequence.new(tracerColor)
        beam.Width0=style.UseBeam and style.BeamWidth0 or 0.01
        beam.Width1=style.UseBeam and style.BeamWidth1 or 0.01
        beam.Segments=style.BeamSegments or 6
        beam.FaceCamera=true
        beam.LightEmission=1
        beam.Transparency=style.UseBeam and style.BeamTransparency or NumberSequence.new(1)
        beam.Enabled=visibleNow and style.UseBeam and true or false
        beam.CurveSize0=0
        beam.CurveSize1=0
        pcall(function()
            beam.Brightness=style.Lightning and 12 or 4
        end)
        if style.Lightning then
            local arc=math.sin(tick()*70)*0.9
            local arc2=math.cos(tick()*53)*0.7
            beam.CurveSize0=arc
            beam.CurveSize1=arc2
        end
    end
    if style.Lightning then
        local fx=bulletTracerState.ensureLightningFx(instRoot, original)
        if fx then
            if fx.Sparks then
                fx.Sparks.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,Color3.new(1,1,1)),
                    ColorSequenceKeypoint.new(1,tracerColor),
                })
                fx.Sparks.Rate=120
                fx.Sparks.Enabled=visibleNow
            end
            if fx.Light then
                fx.Light.Color=tracerColor
                fx.Light.Brightness=3.5 + math.abs(math.sin(tick()*35))*2
                fx.Light.Enabled=visibleNow
            end
        end
    elseif original and original.CustomFx then
        if original.CustomFx.Sparks then
            original.CustomFx.Sparks.Enabled=false
        end
        if original.CustomFx.Light then
            original.CustomFx.Light.Enabled=false
        end
    end
end

function bulletTracerState.resolveTrackRoot(inst)
    if not inst then return nil end
    if inst:IsA("BasePart") then
        return inst
    end
    if inst:IsA("Attachment") and inst.Parent and inst.Parent:IsA("BasePart") then
        return inst.Parent
    end
    if inst:IsA("Trail") or inst:IsA("Beam") then
        local p=inst.Parent
        while p do
            if p:IsA("BasePart") then
                return p
            end
            p=p.Parent
        end
    end
    if inst:IsA("Model") then
        return inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart",true)
    end
    return inst:FindFirstChildWhichIsA("BasePart",true)
end

function bulletTracerState.shouldTrack(inst)
    if not inst or not inst.Parent then return false end
    local lower=string.lower(inst.Name or "")
    if lower=="visualtracer" or string.find(lower,"tracer",1,true) or string.find(lower,"bullet",1,true) or string.find(lower,"projectile",1,true) then
        return true
    end
    if inst:IsA("Trail") or inst:IsA("Beam") then
        return true
    end
    local root=bulletTracerState.resolveTrackRoot(inst)
    if not root then return false end
    if root:FindFirstChild("Trail",true) or root:FindFirstChildWhichIsA("Beam",true) then
        return true
    end
    return root:IsDescendantOf(bulletTracerState.getEffectsFolder() or workspace)
end

function bulletTracerState.process(inst)
    if not Cfg.BulletTracer or not bulletTracerState.shouldTrack(inst) then
        return
    end
    local instRoot=bulletTracerState.resolveTrackRoot(inst)
    if not instRoot or bulletTracerState.tracers[instRoot] then return end
    local original={}
    if instRoot:IsA("BasePart") then
        original.Color=instRoot.Color
        original.Material=instRoot.Material
        original.Transparency=instRoot.Transparency
        original.Size=instRoot.Size
    end
    local trail=instRoot:FindFirstChild("Trail",true)
    if trail then
        original.Trail={
            Color=trail.Color,
            Lifetime=trail.Lifetime,
            Enabled=trail.Enabled,
            Transparency=trail.Transparency,
            WidthScale=trail.WidthScale,
        }
    end
    local beam=inst:FindFirstChildWhichIsA("Beam",true)
    if beam then
        original.Beam={
            Color=beam.Color,
            Width0=beam.Width0,
            Width1=beam.Width1,
            Transparency=beam.Transparency,
        }
    end
    original.ShowAt=tick()+0.025
    bulletTracerState.tracers[instRoot]=original
    pcall(function()
        if (not trail) and instRoot:IsA("BasePart") then
            local a0=Instance.new("Attachment")
            local a1=Instance.new("Attachment")
            a0.Name="XFentTracerA0"
            a1.Name="XFentTracerA1"
            a0.Position=Vector3.new(0,0,instRoot.Size.Z*0.5)
            a1.Position=Vector3.new(0,0,-instRoot.Size.Z*0.5)
            a0.Parent=instRoot
            a1.Parent=instRoot
            trail=Instance.new("Trail")
            trail.Name="XFentTracerTrail"
            trail.Attachment0=a0
            trail.Attachment1=a1
            trail.Color=ColorSequence.new(bulletTracerState.getColor())
            trail.Lifetime=Cfg.BulletTracerLifetime
            trail.FaceCamera=true
            trail.Transparency=NumberSequence.new({
                NumberSequenceKeypoint.new(0,0),
                NumberSequenceKeypoint.new(1,1)
            })
            trail.WidthScale=NumberSequence.new({
                NumberSequenceKeypoint.new(0,0.28),
                NumberSequenceKeypoint.new(1,0)
            })
            trail.Parent=instRoot
            original.CustomTrail={A0=a0,A1=a1,Trail=trail}
        end
        bulletTracerState.applyStyle(instRoot,trail,beam,original)
    end)
end

function bulletTracerState.bindFolder(folder)
    if not folder then return end
    table.insert(bulletTracerState.connections, folder.ChildAdded:Connect(function(child)
        task.defer(function()
            pcall(function() bulletTracerState.process(child) end)
        end)
    end))
    table.insert(bulletTracerState.connections, folder.DescendantAdded:Connect(function(desc)
        task.defer(function()
            pcall(function() bulletTracerState.process(desc) end)
        end)
    end))
    for _,child in ipairs(folder:GetChildren()) do
        pcall(function() bulletTracerState.process(child) end)
    end
    for _,desc in ipairs(folder:GetDescendants()) do
        pcall(function() bulletTracerState.process(desc) end)
    end
end

function bulletTracerState.ensureWatcher()
    bulletTracerState.disconnectAll()
    local noCol=workspace:FindFirstChild("NoCollision") or workspace:FindFirstChild("nocollision")
    if noCol then
        table.insert(bulletTracerState.connections, noCol.ChildAdded:Connect(function(child)
            if string.lower(child.Name)=="effects" then
                task.defer(function()
                    pcall(function() bulletTracerState.bindFolder(child) end)
                end)
            end
        end))
    else
        table.insert(bulletTracerState.connections, workspace.ChildAdded:Connect(function(child)
            if string.lower(child.Name)=="nocollision" then
                task.defer(function()
                    local effects=child:FindFirstChild("Effects") or child:FindFirstChild("effects")
                    if effects then
                        pcall(function() bulletTracerState.bindFolder(effects) end)
                    end
                end)
            end
        end))
    end
    bulletTracerState.bindFolder(bulletTracerState.getEffectsFolder())
end

function bulletTracerState.refreshActive()
    if not Cfg.BulletTracer then return end
    for tracer,original in pairs(bulletTracerState.tracers) do
        if not tracer or not tracer.Parent then
            bulletTracerState.tracers[tracer]=nil
        else
            pcall(function()
                local trail=tracer:FindFirstChild("Trail",true)
                if not trail and original and original.CustomTrail and original.CustomTrail.Trail then
                    trail=original.CustomTrail.Trail
                end
                local beam=tracer:FindFirstChildWhichIsA("Beam",true)
                if (not beam) and original and original.CustomBeam and original.CustomBeam.Beam then
                    beam=original.CustomBeam.Beam
                end
                bulletTracerState.applyStyle(tracer,trail,beam,original)
            end)
        end
    end
end

