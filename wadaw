local function getNPCHealthInfo(entry)
    local hum=entry.humanoid
    if hum and hum.Parent then
        local maxHealth=hum.MaxHealth or 0
        local health=hum.Health or 0
        return health,maxHealth,maxHealth>0 and health>0,true
    end
    local model=entry.model
    if model then
        local hpValue=model:FindFirstChild("Health",true) or model:FindFirstChild("HP",true)
        local maxValue=model:FindFirstChild("MaxHealth",true) or model:FindFirstChild("MaxHP",true)
        local health=hpValue and hpValue.Value or nil
        local maxHealth=maxValue and maxValue.Value or health
        if type(health)=="number" then
            return health,maxHealth or health,health>0,true
        end
        if isAIZoneModel(model) then
            return nil,nil,true,false
        end
    end
    return nil,nil,false,false
