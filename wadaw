function ensureFOV()
    if fovCircle then
        return fovCircle
    end
    fovCircle={}
    for i=1,120 do
        local seg=Drawing.new("Line")
        seg.Visible=false
        seg.Color=Color3.fromRGB(255,255,255)
        seg.Transparency=0.92
        seg.Thickness=1.5
        fovCircle[i]=seg
    end
    return fovCircle
end

function hideFOV()
    if not fovCircle then return end
    for _,seg in ipairs(fovCircle) do
        seg.Visible=false
    end
end

function renderFOV(center,radius,color)
    local segments=ensureFOV()
    local sides=#segments
    local ringColor=color or Color3.fromRGB(255,255,255)
    for i=1,sides do
        local a1=((i-1)/sides)*math.pi*2
        local a2=(i/sides)*math.pi*2
        local p1=Vector2.new(center.X+math.cos(a1)*radius,center.Y+math.sin(a1)*radius)
        local p2=Vector2.new(center.X+math.cos(a2)*radius,center.Y+math.sin(a2)*radius)
        local seg=segments[i]
        seg.From=p1
        seg.To=p2
        seg.Color=ringColor
        seg.Transparency=0.92
        seg.Thickness=1.5
        seg.Visible=true
    end
end

