        params.FilterType=Enum.RaycastFilterType.Exclude
        local ignore={Camera}
        if LocalPlayer.Character then table.insert(ignore,LocalPlayer.Character) end
        params.FilterDescendantsInstances=ignore
        params.IgnoreWater=true
        local hit=workspace:Raycast(origin, part.Position-origin, params)
        if not hit then return true end
        return hit.Instance and hit.Instance:IsDescendantOf(part.Parent)
    end
    local function solveQuad(a,b,c)
        local d=b^2-4*a*c; if d<0 then return nil end
        local sq=math.sqrt(d)
        local r1=(-b-sq)/(2*a); local r2=(-b+sq)/(2*a)
        if r1>0 and r1<r2 then return math.sqrt(r1) end
        if r2>0 then return math.sqrt(r2) end
    end
    local function flightTime(dir,grav,speed)
        return solveQuad(grav:Dot(grav)/4, grav:Dot(dir)-speed^2, dir:Dot(dir)) or 0
    end
    local function getTarget()
        local vp=Camera.ViewportSize; local ctr=Vector2.new(vp.X/2,vp.Y/2)
        local radius=Cfg.SilentAimFOVRadius or 600; local best,bestD=nil,radius
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and isAlive(p) then
                local part=p.Character:FindFirstChild(Cfg.SilentAimHitPart or "Head")
                    or p.Character:FindFirstChild("HumanoidRootPart")
                if part then
                    if Cfg.SilentAimWallCheck and not hasLOS(Camera.CFrame.Position,part) then continue end
                    local sp,on=Camera:WorldToViewportPoint(part.Position)
                    if on and sp.Z>0 then
                        local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
                        if d<bestD then bestD=d; best=part end
                    end
                end
            end
        end
        return best
    end
    local function getPredicted(target,origin,spd,acc)
        local g=Vector3.yAxis*(acc*2)
        local t=flightTime(target.Position-origin,g,spd)
        return target.Position+(target.AssemblyLinearVelocity or Vector3.zero)*t
    end
    local function getDrop(origin,targetPos,spd,acc)
        local g=Vector3.yAxis*(acc*2)
        return 0.5*g*flightTime(targetPos-origin,g,spd)^2
    end
    silentAim.getTarget=getTarget
    silentAim.getPredicted=getPredicted
    silentAim.getDrop=getDrop

    -- FOV circle render
    RunService.RenderStepped:Connect(function()
        if not silentAim.fovCircle then
            silentAim.fovCircle=Drawing.new("Circle")
            silentAim.fovCircle.Filled=false; silentAim.fovCircle.Thickness=1
            silentAim.fovCircle.NumSides=64; silentAim.fovCircle.Transparency=1
        end
        local vp=Camera.ViewportSize
        silentAim.fovCircle.Position=Vector2.new(vp.X/2,vp.Y/2)
        silentAim.fovCircle.Radius=Cfg.SilentAimFOVRadius or 600
        silentAim.fovCircle.Color=Color3.fromRGB(255,80,80)
        silentAim.fovCircle.Visible=Cfg.SilentAimEnabled and Cfg.SilentAimFOVCircle
    end)

    -- Hook search runs in background after 3s to let game modules load
    task.spawn(function()
        if not hookfunction then return end
        task.wait(3)
        local BulletModule=nil
        -- Strategy 1: getgc scan
        if getgc then
            pcall(function()
                for _,v in ipairs(getgc(true)) do
                    if type(v)=="table" and type(rawget(v,"CreateBullet"))=="function" then
                        BulletModule=v; break
                    end
                end
            end)
        end
        -- Strategy 2: recursive name search
        if not BulletModule then
            local function searchName(parent,depth)
                if depth>8 then return end
                for _,child in ipairs(parent:GetChildren()) do
                    if child:IsA("ModuleScript") and string.lower(child.Name)=="bullet" then
                        local ok,mod=pcall(require,child)
                        if ok and type(mod)=="table" and mod.CreateBullet then BulletModule=mod; return end
                    end
                    searchName(child,depth+1)
                    if BulletModule then return end
                end
            end
            searchName(ReplicatedStorage,0)
        end
        -- Strategy 3: require all ModuleScripts
        if not BulletModule then
            local function deepSearch(parent,depth)
                if depth>5 then return end
                for _,child in ipairs(parent:GetChildren()) do
                    if child:IsA("ModuleScript") then
                        local ok,mod=pcall(require,child)
                        if ok and type(mod)=="table" and type(rawget(mod,"CreateBullet"))=="function" then
                            BulletModule=mod; return
                        end
                    end
                    deepSearch(child,depth+1)
                    if BulletModule then return end
                end
            end
            deepSearch(ReplicatedStorage,0)
        end
        if not BulletModule then return end
        local origCreate
        origCreate=hookfunction(BulletModule.CreateBullet,function(a,b,c,d,aim,e,ammo,tickVal,recoil)
            if Cfg.NoRecoilAmmo then recoil=0 end
            if not Cfg.SilentAimEnabled then return origCreate(a,b,c,d,aim,e,ammo,tickVal,recoil) end
            local target=getTarget()
            if not target then return origCreate(a,b,c,d,aim,e,ammo,tickVal,recoil) end
            local dat=ReplicatedStorage:FindFirstChild("AmmoTypes") and ReplicatedStorage.AmmoTypes:FindFirstChild(ammo)
            local spd=dat and dat:GetAttribute("MuzzleVelocity") or 900
            local acc=dat and dat:GetAttribute("ProjectileDrop") or 0
            if dat then dat:SetAttribute("Drag",0) end
            local origin=aim and aim.Position or Camera.CFrame.Position
            local targetPos=Cfg.SilentAimPrediction and getPredicted(target,origin,spd,acc) or target.Position
            local drop=getDrop(origin,targetPos,spd,acc)
            return origCreate(a,b,c,d,{CFrame=CFrame.new(origin,targetPos+drop)},e,ammo,tickVal,recoil)
        end)
        silentAim.hooked=true
    end)
end

