function hudState.invViewerSetQty(index,amount)
    local state=hudState.invViewer
    local lbl=state.stashQty and state.stashQty[index]
    if not lbl then return end
    local qty=tonumber(amount) or 1
    if qty>=1000 then lbl.Text=tostring(math.floor(qty/1000)).."K"
    else lbl.Text="x"..qty end
    lbl.Visible=true
end

function hudState.invViewerGetValue(inventory)
    if not inventory then return 0 end
    local total=0
    local itemMap=hudState.invViewerBuildItemMap()
    for _,entry in ipairs(inventory:GetChildren()) do
        local slotName=tostring(entry:GetAttribute("Slot") or "")
        local nested=entry:FindFirstChild("Inventory")
        if nested and string.find(slotName,"Clothing",1,true) then
            for _,nestedItem in ipairs(nested:GetChildren()) do
                local catalog=itemMap[nestedItem.Name]
                local props=catalog and catalog:FindFirstChild("ItemProperties")
                local price=(props and props:GetAttribute("Price")) or 1
                local itemType=props and props:GetAttribute("ItemType")
                if nestedItem.Name=="Rubles" then
                    total=total+(nestedItem:GetAttribute("Amount") or 1)
                else
                    if price>=10 then
                        if itemType=="Extra" then price=price*0.4
                        elseif itemType=="Ammo" then price=price*(nestedItem:GetAttribute("Amount") or 1)*0.7
                        elseif itemType=="Clothing" then price=price*0.35
                        elseif itemType=="Medical" then price=price*0.75
                        elseif itemType=="Barter" then price=price*0.4
                        end
                    end
                    total=total+price
                end
            end
        end
    end
    return math.floor(total)
end

function hudState.invViewerPopulate(inventory)
    local state=hudState.invViewer
    hudState.invViewerClear()
    if not inventory then return end
    local clothingIndex=4; local weaponIndex=1; local attachOffset=0; local stashIndex=1
    for _,entry in ipairs(inventory:GetChildren()) do
        local slotName=tostring(entry:GetAttribute("Slot") or "")
        if string.find(slotName,"Clothing",1,true) then
            if state.mainSlots and state.mainSlots[clothingIndex] then
                hudState.invViewerSetSlot(state.mainSlots[clothingIndex],hudState.invViewerGetIcon(entry.Name))
                clothingIndex=clothingIndex+1
            end
        elseif entry:FindFirstChild("Attachments") then
            if state.mainSlots and state.mainSlots[weaponIndex] then
                hudState.invViewerSetSlot(state.mainSlots[weaponIndex],hudState.invViewerGetIcon(entry.Name))
                for _,att in ipairs(entry.Attachments:GetChildren()) do
                    local slotOffset=nil
                    local attSlot=tostring(att:GetAttribute("Slot") or "")
                    if attSlot=="Magazine" then slotOffset=1
                    elseif attSlot=="Sight" then slotOffset=2
                    elseif attSlot=="Muzzle" then slotOffset=3
                    elseif attSlot=="Extra" then slotOffset=4 end
                    if slotOffset and state.attachSlots and state.attachSlots[attachOffset+slotOffset] then
                        hudState.invViewerSetSlot(state.attachSlots[attachOffset+slotOffset],hudState.invViewerGetIcon(att.Name))
                    end
                end
                attachOffset=attachOffset+4; weaponIndex=weaponIndex+1
            end
        end
        if Cfg.FullInventoryChecker then
            local nested=entry:FindFirstChild("Inventory")
            if nested and entry.Name~="KeyChain" then
                for _,nestedItem in ipairs(nested:GetChildren()) do
                    if state.stashSlots and state.stashSlots[stashIndex] then
                        hudState.invViewerSetSlot(state.stashSlots[stashIndex],hudState.invViewerGetIcon(nestedItem.Name))
                        hudState.invViewerSetQty(stashIndex,nestedItem:GetAttribute("Amount") or 1)
                        stashIndex=stashIndex+1
                    end
                end
            end
        end
    end
end

