local introLastConfetti=0
local function triggerIntroConfetti(inp)
    if not introOpen then return end
    if not (inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch) then return end
    local now=tick()
    if now-introLastConfetti<0.08 then return end
    introLastConfetti=now
    burstIntroConfetti(inp.Position)
end
local function triggerIntroConfettiAt(guiObject)
    if not introOpen or not guiObject then return end
    local now=tick()
    if now-introLastConfetti<0.08 then return end
    introLastConfetti=now
    local pos=guiObject.AbsolutePosition+guiObject.AbsoluteSize*0.5
    burstIntroConfetti(pos)
end
