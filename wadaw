local function registerUIPositionTarget(posKey,target)
    if not posKey or not target then return end
    uiPositionRefs[posKey]=target
    local saved=Cfg.UIPositions and Cfg.UIPositions[posKey]
    if typeof(saved)=="UDim2" then
        target.Position=saved
    end
end
applySavedUIPositions=function()
    for posKey,target in pairs(uiPositionRefs) do
        local saved=Cfg.UIPositions and Cfg.UIPositions[posKey]
        if target and target.Parent and typeof(saved)=="UDim2" then
            target.Position=saved
        end
    end
