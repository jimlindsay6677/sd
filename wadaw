local privacyState={applied=nil,gui=nil,frame=nil,label=nil,chatTexts=nil,lastChatScan=0,lastChatMask=nil}
privacyState.isChatGuiObject=function(obj)
    local p=obj
    local depth=0
    while p and depth<8 do
        local n=string.lower(tostring(p.Name or ""))
        if string.find(n,"chat",1,true) then
            return true
        end
        p=p.Parent
        depth=depth+1
    end
    return false
end
privacyState.applyChat=function(playerGui,wantVisible)
    if not playerGui then return end
    local now=tick()
    if not privacyState.chatTexts or now-privacyState.lastChatScan>=4 then
        privacyState.lastChatScan=now
        privacyState.chatTexts={}
        for _,obj in ipairs(playerGui:GetDescendants()) do
            if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and privacyState.isChatGuiObject(obj) then
                privacyState.chatTexts[#privacyState.chatTexts+1]=obj
            end
        end
    end
    local replacements={}
    if Cfg.PrivacyMode then
        if Cfg.PrivacyScope=="Everyone" then
            for _,p in ipairs(Players:GetPlayers()) do
                replacements[#replacements+1]={from=p.DisplayName,to="Player"}
                if p.Name~=p.DisplayName then
                    replacements[#replacements+1]={from=p.Name,to="Player"}
                end
            end
        else
            replacements[1]={from=LocalPlayer.DisplayName,to="Player"}
            if LocalPlayer.Name~=LocalPlayer.DisplayName then
                replacements[2]={from=LocalPlayer.Name,to="Player"}
            end
        end
    end
    for i=#privacyState.chatTexts,1,-1 do
        local obj=privacyState.chatTexts[i]
        if obj and obj.Parent then
            local original=obj:GetAttribute("XFentPrivacyText")
            if wantVisible then
                if original~=nil then
                    obj.Text=original
                    obj:SetAttribute("XFentPrivacyText",nil)
                end
            else
                local src=original or obj.Text
                local masked=src
                for _,rep in ipairs(replacements) do
                    local from=tostring(rep.from or "")
                    if from~="" then
                        masked=string.gsub(masked,from,rep.to)
                    end
                end
                if masked~=obj.Text then
                    if original==nil then
                        obj:SetAttribute("XFentPrivacyText",obj.Text)
                    end
                    obj.Text=masked
                end
            end
        else
            table.remove(privacyState.chatTexts,i)
        end
    end
    privacyState.lastChatMask=wantVisible
end
local function applyPrivacyUI(forceRefresh)
