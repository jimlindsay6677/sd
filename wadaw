local function getTarget()
    local vp=Camera.ViewportSize; local ctr=Vector2.new(vp.X/2,vp.Y/2); local best,bestD=nil,Cfg.AimbotFOV
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer and p.Character then
            local part=p.Character:FindFirstChild(Cfg.AimbotPart) or p.Character:FindFirstChild("HumanoidRootPart")
            local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health>0 then
                local sp,on=Camera:WorldToViewportPoint(part.Position)
                if on and sp.Z>0 then local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude; if d<bestD then bestD=d; best={type="player",obj=p} end end
            end
        end
    end
    if Cfg.AimbotNPC then
        for _,entry in ipairs(npcState.cache) do
            local nchar=entry.model
            local root=entry.root
            local _,_,alive=getNPCHealthInfo(entry)
            if alive and nchar and nchar.Parent and root and root.Parent then
                local part=getNPCTargetPart(nchar,root)
                if part then
                    local sp,on=Camera:WorldToViewportPoint(part.Position)
                    if on and sp.Z>0 then local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude; if d<bestD then bestD=d; best={type="npc",obj=nchar,part=part} end end
                end
            end
        end
    end
    return best
end
local lastTargetUpdate=0
local cachedTarget=nil
local function getTargetPart(tgt)
    if not tgt then return nil end
    local function getBaseTargetPart()
        if tgt.type=="player" then
            local char=tgt.obj and tgt.obj.Character
            return char and (char:FindFirstChild(Cfg.AimbotPart) or char:FindFirstChild("HumanoidRootPart")) or nil
        elseif tgt.type=="npc" then
            local model=tgt.obj
            local root=tgt.part or getModelRoot(model)
            return getNPCTargetPart(model,root)
        end
        return nil
    end
    if not Cfg.AimbotRandomPart then
        return getBaseTargetPart()
    end

    local model=nil
    if tgt.type=="player" then
        model=tgt.obj and tgt.obj.Character
    elseif tgt.type=="npc" then
        model=tgt.obj
    end
    if not model then
        return getBaseTargetPart()
    end

    -- Random-part mode only picks from body parts that are currently visible.
    -- If only head/torso are exposed, the randomizer stays inside that visible subset.
    local now=tick()
    if tgt.randomPart and tgt.randomPart.Parent and tgt.randomPart:IsDescendantOf(model) and tgt.randomPartUntil and now<tgt.randomPartUntil then
        local origin=Camera.CFrame.Position
        local direction=tgt.randomPart.Position-origin
        if direction.Magnitude>0.001 then
            local params=RaycastParams.new()
            params.FilterType=Enum.RaycastFilterType.Exclude
            params.FilterDescendantsInstances={LocalPlayer.Character,Camera}
            params.IgnoreWater=true
            local hit=workspace:Raycast(origin,direction,params)
            if not hit or hit.Instance==tgt.randomPart or hit.Instance:IsDescendantOf(model) then
                return tgt.randomPart
            end
        end
    end

    local visibleParts={}
    for _,partName in ipairs(PARTS_CYCLE) do
        local bodyPart=model:FindFirstChild(partName)
        if bodyPart and bodyPart:IsA("BasePart") then
            local origin=Camera.CFrame.Position
            local direction=bodyPart.Position-origin
            if direction.Magnitude>0.001 then
                local params=RaycastParams.new()
                params.FilterType=Enum.RaycastFilterType.Exclude
                params.FilterDescendantsInstances={LocalPlayer.Character,Camera}
                params.IgnoreWater=true
                local hit=workspace:Raycast(origin,direction,params)
                if not hit or hit.Instance==bodyPart or hit.Instance:IsDescendantOf(model) then
                    visibleParts[#visibleParts+1]=bodyPart
                end
            end
        end
    end
    if #visibleParts==0 then
        return getBaseTargetPart()
    end
    tgt.randomPart=visibleParts[math.random(1,#visibleParts)]
    tgt.randomPartUntil=now+0.12
    return tgt.randomPart
end
-- Prediction keeps the lock point slightly ahead of moving targets by using
-- their current velocity and an estimated projectile travel time.
local function getPredictedAimPosition(tgt, part)
    if not tgt or not part or not part.Parent then
        return nil
    end
    if not Cfg.PredictShotEX then
        return part.Position
    end

    local velocity=Vector3.zero
    if tgt.type=="player" then
        local char=tgt.obj and tgt.obj.Character
        local root=char and char:FindFirstChild("HumanoidRootPart")
        velocity=(root and root.AssemblyLinearVelocity) or part.AssemblyLinearVelocity or Vector3.zero
    elseif tgt.type=="npc" then
        local root=tgt.part or getModelRoot(tgt.obj)
        velocity=(root and root.AssemblyLinearVelocity) or part.AssemblyLinearVelocity or Vector3.zero
    else
        velocity=part.AssemblyLinearVelocity or Vector3.zero
    end

    local origin=Camera.CFrame.Position
    local distance=(part.Position-origin).Magnitude

    -- This is a lightweight estimate so it stays stable in the UI script even
    -- without reading every game's exact live ammo stats each frame.
    local assumedProjectileSpeed=950
    local travelTime=distance/assumedProjectileSpeed
    local horizontalLead=Vector3.new(velocity.X,0,velocity.Z)*travelTime

    -- A small vertical carry helps a bit on jumping/falling targets without
    -- making the camera overshoot wildly.
    local verticalLead=Vector3.new(0,velocity.Y*travelTime*0.35,0)
    return part.Position+horizontalLead+verticalLead
end

local function isTargetStillValid(tgt)
    local part=getTargetPart(tgt)
    if not part or not part.Parent then return false,nil end
    local sp,on=Camera:WorldToViewportPoint(part.Position)
    if not on or sp.Z<=0 then return false,nil end
    local vp=Camera.ViewportSize
    local ctr=Vector2.new(vp.X/2,vp.Y/2)
    local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
    return d<=Cfg.AimbotFOV*1.35,part
end
local function getCachedTarget(now)
    if now-lastTargetUpdate>=0.05 then
        lastTargetUpdate=now
        local keep,part=isTargetStillValid(cachedTarget)
        if keep then
            cachedTarget.part=part
        else
            cachedTarget=getTarget()
        end
    end
    return cachedTarget
end

-- Apply a saved offset to workspace.Camera.ViewModel without causing drift.
-- If the game already produced a fresh pose this frame, we offset that pose
-- directly. If not, we peel off our last offset first so the model does not
-- slowly walk away from the camera when the same pose repeats.
local function applyViewModelOffset()
    local viewModel=Camera and Camera:FindFirstChild("ViewModel")
    if not viewModel or not viewModel:IsA("Model") then
        viewModelOffsetState.model=nil
        viewModelOffsetState.lastApplied=Vector3.zero
        viewModelOffsetState.lastFinalPivot=nil
        return
    end

    local desiredOffset=Vector3.new((Cfg.VMOffsetX or 0)/10,(Cfg.VMOffsetY or 0)/10,(Cfg.VMOffsetZ or 0)/10)
    if viewModelOffsetState.model~=viewModel then
        viewModelOffsetState.model=viewModel
        viewModelOffsetState.lastApplied=Vector3.zero
        viewModelOffsetState.lastFinalPivot=nil
    end

    local currentPivot=viewModel:GetPivot()
    local pivot=currentPivot
    local lastApplied=viewModelOffsetState.lastApplied
    local lastFinalPivot=viewModelOffsetState.lastFinalPivot

    -- When the current pose still matches the last pose we wrote, remove our
    -- previous offset before applying the new one. Otherwise trust the game's
    -- updated pose and offset that instead.
    if lastApplied.Magnitude>0 and lastFinalPivot and (currentPivot.Position-lastFinalPivot.Position).Magnitude<=0.001 then
        pivot=pivot*CFrame.new(-lastApplied.X,-lastApplied.Y,-lastApplied.Z)
    end

    local finalPivot=pivot*CFrame.new(desiredOffset.X,desiredOffset.Y,desiredOffset.Z)
    viewModel:PivotTo(finalPivot)
    viewModelOffsetState.lastApplied=desiredOffset
    viewModelOffsetState.lastFinalPivot=finalPivot
end

local function isTargetVisible(tgt, part)
    if not tgt or not part or not part.Parent then
        return false,nil
    end
    local origin=Camera.CFrame.Position
    local direction=part.Position-origin
    if direction.Magnitude<=0.001 then
        return false,nil
    end
    local params=RaycastParams.new()
    params.FilterType=Enum.RaycastFilterType.Exclude
    local ignore={}
    if LocalPlayer.Character then
        ignore[#ignore+1]=LocalPlayer.Character
    end
    if Camera then
        -- Ignore the local camera tree so the player's own ViewModel does not
        -- get mistaken for world geometry and break visibility-based ESP.
        ignore[#ignore+1]=Camera
    end
