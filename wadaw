RunService.RenderStepped:Connect(function(dt)
    if Unloaded then return end
    local now=tick()
    local runtime=hudState.runtime
    if now-runtime.lastPrivacyUpdate>=1 then
        runtime.lastPrivacyUpdate=now
        applyPrivacyUI()
    end
    if Cfg.ModDetector and now-runtime.lastModUpdate>=5 then
        runtime.lastModUpdate=now
        for _,p in ipairs(Players:GetPlayers()) do
            modState.queueAlert(p)
        end
    end
    runtime.fpsBuffer[#runtime.fpsBuffer+1]=dt
    runtime.fpsSum=runtime.fpsSum+dt
    if #runtime.fpsBuffer>20 then
        runtime.fpsSum=runtime.fpsSum-table.remove(runtime.fpsBuffer,1)
    end
    if runtime.fpsSum>0 then
        runtime.FPS=math.floor(#runtime.fpsBuffer/runtime.fpsSum)
    end

    -- Match the older ESP cadence so player boxes stay responsive without
    -- forcing every world/NPC helper to run at full render rate.
    local interval=0.033
    if now-lastRender>=interval then
        lastRender=now
        local playersNow=Players:GetPlayers()
        if not Cfg.Enabled then
            for _,p in ipairs(playersNow) do hideAll(ESPObjects[p]) end
        else
            for _,p in ipairs(playersNow) do
                if p~=LocalPlayer then
                    if not ESPObjects[p] then createESP(p) end
                    updateESP(p)
                end
            end
        end
    end

    if now-runtime.lastRadarUpdate>=0.16 then
        runtime.lastRadarUpdate=now
        updateRadar()
    end

    -- NPC ESP already draws from a cached registry, so we can refresh the
    -- on-screen labels at a slower cadence without hammering the render loop.
    if now-runtime.lastNPCUpdate>=0.08 then
        runtime.lastNPCUpdate=now
        updateNPCESP()
    end

    -- World overlays are cheaper and smoother when they refresh slightly slower
    -- than player ESP instead of trying to keep full render cadence.
    local worldInterval=(Cfg.CorpseESP or Cfg.DroppedItemESP or #hudState.teammates>0) and 0.08 or 0.16
    if now-runtime.lastWorldUpdate>=worldInterval then
        runtime.lastWorldUpdate=now
        updateWorldESP()
    end

    hudState.visHud.Visible=Cfg.TargetVisibleHUD and Cfg.ShowSysBar
    if hudState.visHud.Visible then
        if now-runtime.lastVisHudUpdate>=0.12 then
            runtime.lastVisHudUpdate=now
            local tgt=getCachedTarget(now)
            local part=tgt and getTargetPart(tgt) or nil
            if tgt and part then
                local visible,hitPart=isTargetVisible(tgt,part)
                if visible then
                    runtime.visHudText="VISIBLE"
                    runtime.visHudColor=Color3.fromRGB(110,255,140)
                else
                    runtime.visHudText="BLOCKED"
                    runtime.visHudColor=THEME.RED
                end
                runtime.visHudHoldUntil=now+0.18
