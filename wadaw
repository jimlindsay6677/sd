-- read common leaderstats layouts without hardcoding one exact game schema.
local function getStatNumber(container,names)
    if not container then return nil end
    for _,name in ipairs(names) do
        local stat=container:FindFirstChild(name)
        if stat and stat.Value~=nil then
            local n=tonumber(stat.Value)
            if n then return n end
        end
    end
    return nil
end
local function getStatNumberDeep(root,names)
    if not root then return nil end
    local direct=getStatNumber(root,names)
    if direct~=nil then return direct end
    for _,desc in ipairs(root:GetDescendants()) do
        if desc.Value~=nil then
            for _,name in ipairs(names) do
                if string.lower(desc.Name)==string.lower(name) then
                    local n=tonumber(desc.Value)
                    if n then return n end
                end
            end
        end
    end
    for _,name in ipairs(names) do
        local attr=tonumber(root:GetAttribute(name))
        if attr then return attr end
    end
    return nil
end
local function getJourneyStats(player)
    if not player then return nil,nil end
    local rsPlayers=ReplicatedStorage:FindFirstChild("Players")
    local rsPlayer=rsPlayers and rsPlayers:FindFirstChild(player.Name)
    local status=rsPlayer and rsPlayer:FindFirstChild("Status")
    local journey=status and status:FindFirstChild("Journey")
    local statistics=journey and journey:FindFirstChild("Statistics")
    if not statistics then
        return nil,nil
    end
    local kills=getStatNumberDeep(statistics,{"Kills","Kill","PlayerKills","KillCount"})
    local deaths=getStatNumberDeep(statistics,{"Deaths","Death","PlayerDeaths","DeathCount"})
    return kills,deaths
end
local function getPlayerKDText(player)
    if not player then return "K/D  --" end
    local leaderstats=player:FindFirstChild("leaderstats") or player:FindFirstChild("Stats") or player:FindFirstChild("stats")
    local rsPlayer=ReplicatedStorage:FindFirstChild("Players") and ReplicatedStorage.Players:FindFirstChild(player.Name)
    local status=rsPlayer and rsPlayer:FindFirstChild("Status")
    local gameplay=status and status:FindFirstChild("GameplayVariables")
    -- Check several common stat containers so K/D still shows up in games that do
    -- not keep kills and deaths only inside leaderstats.
    local containers={leaderstats,player,status,gameplay,rsPlayer}
    local kills,deaths=getJourneyStats(player)
    for _,container in ipairs(containers) do
        if kills==nil then
            kills=getStatNumberDeep(container,{"Kills","Kill","KOs","Elims","Eliminations","PlayerKills","KillCount"})
        end
        if deaths==nil then
            deaths=getStatNumberDeep(container,{"Deaths","Death","WOs","Downs","PlayerDeaths","DeathCount"})
        end
    end
    if kills==nil and deaths==nil then
        return "K/D  --"
    end
    kills=kills or 0
    deaths=deaths or 0
    if deaths<=0 then
        return string.format("K/D  %d",kills)
    end
    return string.format("K/D  %.2f",kills/deaths)
end
