local ProjectCodes={}
local _ihCamera=workspace.CurrentCamera
do
    local __namecall
    __namecall=hookmetamethod(game,"__namecall",function(self,...)
        local Method=getnamecallmethod()
        local Arguments={...}
        if not checkcaller() then
            -- Scale ray distance so bullets register instantly
            if Method=="Raycast" and Cfg.InstaHit then
                if Arguments[3] and Arguments[3].CollisionGroup=="WeaponRay" then
                    Arguments[2]=Arguments[2]*(Cfg.FastBullets and 99 or 99999999)
                end
            end
            -- Correct server tick so hit registers at the right time
            if Method=="FireServer" then
                if self.Name=="ProjectileInflict" and Cfg.InstaHit then
                    local code=Arguments[3]
                    if ProjectCodes[code] then
                        local Info=ProjectCodes[code]
                        local Origin=Info.Origin
                        local Speed=Info.Speed
                        local Tick=Info.Tick
                        local Destination=Arguments[1].CFrame.p
                        local Distance=(Origin-Destination).Magnitude
                        local TimeToHit=Distance/Speed
                        local Velocity=Arguments[1].Velocity
                        local Predicted=Destination+(Velocity*TimeToHit)
                        local Delta=(Predicted-Destination).Magnitude
                        local k=0.013
                        local NewSpeed=Speed-k*Speed^2*TimeToHit^2
                        TimeToHit=TimeToHit+(Delta/math.max(NewSpeed,1))
                        if TimeToHit>0 then Tick=Tick+TimeToHit end
                        Arguments[4]=Tick
                        ProjectCodes[code]=nil
                    end
                end
            end
            -- Record projectile metadata when bullet is fired
            if Method=="InvokeServer" then
                if self.Name=="FireProjectile" and Cfg.InstaHit then
                    task.spawn(function()
                        local status=ReplicatedStorage.Players[LocalPlayer.Name].Status.GameplayVariables
                        local EquippedItem=status.EquippedTool.Value
                        local BulletCaliber=nil
                        if EquippedItem then
                            local LoadedAmmo=EquippedItem:FindFirstChild("LoadedAmmo",true)
                            if LoadedAmmo then
                                local Caliber=LoadedAmmo:GetChildren()[1]
                                if Caliber then BulletCaliber=Caliber:GetAttribute("AmmoType") end
                            end
                        end
                        local ammoData=ReplicatedStorage.AmmoTypes:FindFirstChild(BulletCaliber)
                        if not ammoData then return end
                        ProjectCodes[Arguments[2]]={
                            Tick=Arguments[3],
                            Direction=Arguments[1],
                            Origin=_ihCamera.CFrame.p,
                            Speed=ammoData:GetAttribute("MuzzleVelocity"),
                        }
                    end)
                end
            end
        end
        return __namecall(self,unpack(Arguments))
    end)
end

