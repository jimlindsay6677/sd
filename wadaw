                    if type(target)=="table" then
                        local pos=(target.obj and getWorldPos(target.obj)) or target.pos
                        target.pos=pos
                        if pos then
                        if not mapState.lookupDots[i] then local f,l=makeMapDot(itemLookup.color,"",6); mapState.lookupDots[i]={dot=f,lbl=l} end
