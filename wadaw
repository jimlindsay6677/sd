        local lr=char and char:FindFirstChild("HumanoidRootPart")
        if lr then
            local camLook=Camera.CFrame.LookVector
            local camYaw=math.atan2(camLook.X,camLook.Z); local camDeg=math.deg(camYaw)
            local dirs={{"N",0},{"E",90},{"S",180},{"W",270}}; local cl,cd="N",999
            for _,d in ipairs(dirs) do local diff=((d[2]-camDeg)%360); if diff>180 then diff=diff-360 end; if math.abs(diff)<cd then cd=math.abs(diff); cl=d[1] end end
            mapState.headingDir.Text=cl; mapState.headingDeg.Text=string.format("%d deg",math.floor((camDeg+360)%360))
            local rotAngle=0; if Cfg.RadarRotate then rotAngle=camYaw end
