                            local owner=getLookupAnchor(drop) or drop
                            if not seen[owner] then
                                local pos=getWorldPos(owner) or getWorldPos(drop) or getWorldPos(obj)
                                if pos then
                                    seen[owner]=true
                                    table.insert(results,{obj=owner,pos=pos,name=matchName,kind="world"})
                                end
                            end
                            break
                        end
                    end
                end
            end
            return
        end
        for _,obj in ipairs(root:GetDescendants()) do
